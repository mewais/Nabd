{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@nabd/domain": ["packages/B01-domain/src/index.ts"],
      "@nabd/dataset": ["packages/B02-dataset/src/index.ts"],
      "@nabd/coverage": ["packages/B03-coverage/src/index.ts"],
      "@nabd/scheduling": ["packages/B04-scheduling/src/index.ts"],
      "@nabd/progression": ["packages/B05-progression/src/index.ts"],
      "@nabd/session": ["packages/B06-session/src/index.ts"],
      "@nabd/nudge": ["packages/B07-nudge/src/index.ts"],
      "@nabd/analytics": ["packages/B08-analytics/src/index.ts"],
      "@nabd/program-editor": ["packages/B09-program-editor/src/index.ts"],
      "@nabd/serialization": ["packages/B10-serialization/src/index.ts"],
      "@nabd/ipc-client": ["packages/B14-ipc-client/src/index.ts"],
      "@nabd/store": ["packages/B15-store/src/index.ts"],
      "@nabd/design-system": ["packages/B16-design-system/src/index.ts"],
      "@nabd/bodymap": ["packages/B17-bodymap/src/index.ts"],
      "@nabd/shell": ["packages/B18-shell/src/index.ts"],
      "@nabd/today": ["packages/B19-today/src/index.ts"],
      "@nabd/planner": ["packages/B20-planner/src/index.ts"],
      "@nabd/progress": ["packages/B21-progress/src/index.ts"],
      "@nabd/modals": ["packages/B22-modals/src/index.ts"]
    }
  }
}
